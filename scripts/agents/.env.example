# GitHub Personal Access Token — used to call GitHub Models (Claude / GPT-4o).
# Your GitHub Copilot subscription covers usage; no separate vendor account needed.
#
# How to create a token:
#   1. Go to https://github.com/settings/personal-access-tokens/new
#   2. Give it a name (e.g. "Catalyst agents")
#   3. Set an expiry (90 days is a sensible default)
#   4. Under "Permissions" → "Account permissions", grant: Models → Read-only
#   5. Click "Generate token" and paste it below
#
GITHUB_TOKEN=github_pat_

# Optional: override the default model (gpt-4o).
# Other available models on GitHub Models: claude-sonnet-4-5, gpt-4o-mini, o3-mini
# MODEL=gpt-4o
